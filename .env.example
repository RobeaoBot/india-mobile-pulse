# India Mobile Pulse - 环境变量配置
# 复制此文件为 .env 并修改配置

# 服务端口
PORT=5000

# 每日自动采集时间（印度时区 IST = UTC+5:30）
DAILY_COLLECTION_TIME=12:00

# LLM 配置（不配置则使用规则引擎）
LLM_PROVIDER=none
# LLM_PROVIDER=openai_compatible
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_MODEL=gpt-4o-mini
# LLM_PROVIDER=gemini
# LLM_GEMINI_API_KEY=xxx
